{
  "name": "apa-app",
  "version": "2.5.0",
  "description": "APA Application - Progressive Web App",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf dist/*",
    "prebuild": "npm run clean",
    "build": "npm run build:css && npm run build:js && npm run build:assets",
    "build:css": "node scripts/build-css.js",
    "build:js": "node scripts/build-js.js",
    "build:assets": "node scripts/build-assets.js",
    "watch": "npm run watch:css & npm run watch:js",
    "watch:css": "node scripts/watch-css.js",
    "watch:js": "node scripts/watch-js.js",
    "dev": "npm run watch",
    "version": "node scripts/update-version.js",
    "postversion": "git add . && git commit -m 'Bump version to %s' && git tag -a v%s -m 'Version %s'",
    "start": "node scripts/serve.js",
    "test": "node scripts/test.js",
    "lint": "node scripts/lint.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "prepare": "husky install && node scripts/setup-git-template.js",
    "commit": "git-cz",
    "setup": "node scripts/setup-git-template.js"
  },
  "keywords": ["apa", "pwa", "web-app"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^17.6.7",
    "@commitlint/config-conventional": "^17.6.7",
    "chokidar": "^3.5.3",
    "commitizen": "^4.3.0",
    "conventional-changelog-cli": "^2.2.2",
    "css-minify": "^2.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "husky": "^8.0.3",
    "postcss": "^8.4.31",
    "postcss-preset-env": "^9.1.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
} 